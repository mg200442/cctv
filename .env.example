# Copy this file to .env and fill in real values. .env is gitignored — never
# commit real tokens/secrets. See CLAUDE.md for setup instructions for each.

# Telegram alert notifications ("Alertas por Telegram" en CLAUDE.md)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# HTTP Basic Auth for the whole dashboard — leave both blank to keep the
# dashboard open with no login (previous/default behavior).
AUTH_USER=
AUTH_PASS=
